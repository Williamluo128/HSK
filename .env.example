# MySQL connection string used by Prisma.
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
# Local: mysql://root@127.0.0.1:3309/hsk
# Aiven: use Service URI but replace ?ssl-mode=REQUIRED with ?sslaccept=strict (Prisma)
# Example: mysql://avnadmin:PASS@mysql-xxx.aivencloud.com:19187/defaultdb?sslaccept=strict
DATABASE_URL="mysql://root:password@localhost:3306/hsk"

# Secret used to sign Auth.js session tokens. Generate with: openssl rand -base64 32
AUTH_SECRET="change-me-to-a-long-random-string"

# Base path/URL for media assets (audio pronunciations, stroke-order GIFs, images).
# The original project keeps these under a /mandarin folder outside the app, with
# audio at <base>/audio/*.mp3 and images at <base>/img/*.gif.
# Media base URL. After running `npm run content:download-audio`, use local files:
NEXT_PUBLIC_MEDIA_BASE_URL="/media"
# Remote source used only by the download script (scripts/download-external-audio.ts):
# MEDIA_REMOTE_BASE="https://stephenmccready.asia/mandarin"
