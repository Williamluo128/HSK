# MySQL connection string used by Prisma.
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="mysql://root:password@localhost:3306/hsk"

# Secret used to sign Auth.js session tokens. Generate with: openssl rand -base64 32
AUTH_SECRET="change-me-to-a-long-random-string"

# Base path/URL for media assets (audio pronunciations, stroke-order GIFs, images).
# The original project keeps these under a /mandarin folder outside the app, with
# audio at <base>/audio/*.mp3 and images at <base>/img/*.gif.
# The original site's media is publicly reachable and used here by default so
# audio/images work out of the box. Point this at your own CDN/folder to self-host.
# Missing files degrade gracefully.
NEXT_PUBLIC_MEDIA_BASE_URL="https://stephenmccready.asia/mandarin"
