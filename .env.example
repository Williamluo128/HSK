# ── Supabase（用户注册 / 登录）──
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
# 仅服务端使用，切勿暴露到浏览器或提交 Git
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# ── MySQL / Aiven（课程内容 + 学习进度，Prisma）──
# Local: mysql://root@127.0.0.1:3309/hsk
# Aiven: replace ?ssl-mode=REQUIRED with ?sslaccept=strict for Prisma
DATABASE_URL="mysql://root:password@localhost:3306/hsk"

NEXT_PUBLIC_MEDIA_BASE_URL="/media"
